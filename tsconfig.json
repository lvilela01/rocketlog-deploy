{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["node", "jest"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "module": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    "strict": true,
    "skipLibCheck": true
  }
}
